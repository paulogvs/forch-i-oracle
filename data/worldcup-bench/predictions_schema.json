{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/mverab/WorldCupBench/schema/predictions_schema.json",
  "title": "WorldCupBench - FIFA World Cup 2026 Predictions Schema",
  "description": "Schema that defines the structure of predictions generated by each AI model for the FIFA World Cup 2026 (48 teams, 104 matches). Covers group stage, knockout stage, and final standings.",
  "type": "object",
  "required": [
    "model_name",
    "timestamp",
    "prompt_version",
    "temperature",
    "group_stage_matches",
    "group_qualifiers",
    "knockout_stage",
    "final_standings"
  ],
  "properties": {
    "model_name": {
      "type": "string",
      "description": "Name of the AI model that generated the predictions (e.g., 'GPT-5.5')."
    },
    "model_id": {
      "type": "string",
      "description": "Model identifier in OpenRouter (e.g., 'openai/gpt-5.5')."
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 date and time when the prediction was generated."
    },
    "prompt_version": {
      "type": "string",
      "description": "Version of the prompt used (e.g., '2.1')."
    },
    "temperature": {
      "type": "number",
      "minimum": 0,
      "maximum": 2,
      "description": "Temperature used for prediction generation."
    },
    "group_stage_matches": {
      "type": "array",
      "description": "Predictions for the 72 group stage matches.",
      "minItems": 72,
      "maxItems": 72,
      "items": { "$ref": "#/definitions/match_prediction" }
    },
    "group_qualifiers": {
      "type": "object",
      "description": "Teams that qualify for the next round from the group stage.",
      "required": ["first_place", "second_place", "best_third_place"],
      "properties": {
        "first_place": {
          "type": "array",
          "description": "List of 12 teams that finish first in their groups (A-L).",
          "minItems": 12,
          "maxItems": 12,
          "items": { "$ref": "#/definitions/group_position" }
        },
        "second_place": {
          "type": "array",
          "description": "List of 12 teams that finish second in their groups (A-L).",
          "minItems": 12,
          "maxItems": 12,
          "items": { "$ref": "#/definitions/group_position" }
        },
        "best_third_place": {
          "type": "array",
          "description": "The 8 best third-place teams that advance to the Round of 32.",
          "minItems": 8,
          "maxItems": 8,
          "items": { "$ref": "#/definitions/group_position" }
        }
      }
    },
    "knockout_stage": {
      "type": "object",
      "description": "Predictions for the knockout elimination stage.",
      "required": [
        "round_of_32",
        "round_of_16",
        "quarter_finals",
        "semi_finals",
        "third_place_match",
        "final"
      ],
      "properties": {
        "round_of_32": {
          "type": "array",
          "description": "Predictions for the 16 Round of 32 matches.",
          "minItems": 16,
          "maxItems": 16,
          "items": { "$ref": "#/definitions/match_prediction" }
        },
        "round_of_16": {
          "type": "array",
          "description": "Predictions for the 8 Round of 16 matches.",
          "minItems": 8,
          "maxItems": 8,
          "items": { "$ref": "#/definitions/match_prediction" }
        },
        "quarter_finals": {
          "type": "array",
          "description": "Predictions for the 4 Quarter Final matches.",
          "minItems": 4,
          "maxItems": 4,
          "items": { "$ref": "#/definitions/match_prediction" }
        },
        "semi_finals": {
          "type": "array",
          "description": "Predictions for the 2 Semi-Final matches.",
          "minItems": 2,
          "maxItems": 2,
          "items": { "$ref": "#/definitions/match_prediction" }
        },
        "third_place_match": {
          "description": "Prediction for the third place match.",
          "$ref": "#/definitions/match_prediction"
        },
        "final": {
          "description": "Prediction for the Grand Final.",
          "$ref": "#/definitions/match_prediction"
        }
      }
    },
    "final_standings": {
      "type": "object",
      "description": "Final tournament positions predicted by the model.",
      "required": ["champion", "runner_up", "third_place", "fourth_place"],
      "properties": {
        "champion": {
          "type": "string",
          "pattern": "^[A-Z]{3}$",
          "description": "Champion team (1st place), 3-letter FIFA code."
        },
        "runner_up": {
          "type": "string",
          "pattern": "^[A-Z]{3}$",
          "description": "Runner-up team (2nd place), 3-letter FIFA code."
        },
        "third_place": {
          "type": "string",
          "pattern": "^[A-Z]{3}$",
          "description": "Third place team (3rd), 3-letter FIFA code."
        },
        "fourth_place": {
          "type": "string",
          "pattern": "^[A-Z]{3}$",
          "description": "Fourth place team (4th), 3-letter FIFA code."
        }
      }
    },
    "usage": {
      "type": "object",
      "description": "Token usage breakdown for rationale and prediction phases.",
      "properties": {
        "rationale": {
          "type": "object",
          "properties": {
            "prompt_tokens": { "type": "integer", "minimum": 0 },
            "completion_tokens": { "type": "integer", "minimum": 0 },
            "total_tokens": { "type": "integer", "minimum": 0 }
          }
        },
        "prediction": {
          "type": "object",
          "properties": {
            "prompt_tokens": { "type": "integer", "minimum": 0 },
            "completion_tokens": { "type": "integer", "minimum": 0 },
            "total_tokens": { "type": "integer", "minimum": 0 }
          }
        },
        "total": {
          "type": "object",
          "properties": {
            "prompt_tokens": { "type": "integer", "minimum": 0 },
            "completion_tokens": { "type": "integer", "minimum": 0 },
            "total_tokens": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "cost_usd": {
      "type": "object",
      "description": "Approximate cost in USD per phase and total.",
      "properties": {
        "rationale": { "type": "number", "minimum": 0 },
        "prediction": { "type": "number", "minimum": 0 },
        "total": { "type": "number", "minimum": 0 }
      }
    }
  },
  "definitions": {
    "match_prediction": {
      "type": "object",
      "description": "Individual match prediction.",
      "required": [
        "match_id",
        "home_team",
        "away_team",
        "predicted_result",
        "predicted_score",
        "probs"
      ],
      "properties": {
        "match_id": {
          "type": "string",
          "description": "Unique match identifier (e.g., 'GS-01', 'R32-73', 'FINAL')."
        },
        "stage": {
          "type": "string",
          "description": "Tournament stage this match belongs to.",
          "enum": [
            "group_stage",
            "round_of_32",
            "round_of_16",
            "quarter_finals",
            "semi_finals",
            "third_place_match",
            "final"
          ]
        },
        "group": {
          "type": ["string", "null"],
          "description": "Group letter (A-L) if group stage; null in knockout stages."
        },
        "home_team": {
          "type": "string",
          "pattern": "^[A-Z]{3}$",
          "description": "Home team, 3-letter FIFA code."
        },
        "away_team": {
          "type": "string",
          "pattern": "^[A-Z]{3}$",
          "description": "Away team, 3-letter FIFA code."
        },
        "predicted_result": {
          "type": "string",
          "description": "Predicted result: home win, draw, or away win.",
          "enum": ["home", "draw", "away"]
        },
        "predicted_score": {
          "type": "object",
          "description": "Predicted score.",
          "required": ["home", "away"],
          "properties": {
            "home": {
              "type": "integer",
              "minimum": 0,
              "description": "Predicted goals for the home team."
            },
            "away": {
              "type": "integer",
              "minimum": 0,
              "description": "Predicted goals for the away team."
            }
          }
        },
        "probs": {
          "type": "object",
          "description": "1X2 probabilities that must sum to 1.0 (±0.02).",
          "required": ["home", "draw", "away"],
          "properties": {
            "home": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "description": "Probability of home team win."
            },
            "draw": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "description": "Probability of draw (0.0 in knockouts)."
            },
            "away": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "description": "Probability of away team win."
            }
          }
        },
        "model_name": {
          "type": "string",
          "description": "Name of the model that generated this match prediction."
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 date and time of this match prediction."
        }
      }
    },
    "group_position": {
      "type": "object",
      "description": "Qualified team with its group of origin.",
      "required": ["team_code", "group"],
      "properties": {
        "team_code": {
          "type": "string",
          "pattern": "^[A-Z]{3}$",
          "description": "3-letter FIFA code of the qualified team."
        },
        "group": {
          "type": "string",
          "description": "Letter of the group of origin (A-L)."
        }
      }
    }
  }
}
