{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "regions": ["iad1"],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" }
      ]
    }
  ],
  "functions": {
    "app/api/predict/route.ts": {
      "maxDuration": 30,
      "memory": 1024
    },
    "app/api/simulate-tournament/route.ts": {
      "maxDuration": 120,
      "memory": 1024
    },
    "app/api/cron/ingest/route.ts": {
      "maxDuration": 60,
      "memory": 512
    },
    "app/api/cron/recalculate/route.ts": {
      "maxDuration": 120,
      "memory": 1024
    },
    "app/api/cron/simulate/route.ts": {
      "maxDuration": 300,
      "memory": 1024
    }
  },
  "crons": [
    {
      "path": "/api/cron/ingest?secret=${CRON_SECRET}",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/recalculate?secret=${CRON_SECRET}",
      "schedule": "0 */12 * * *"
    },
    {
      "path": "/api/cron/simulate?secret=${CRON_SECRET}",
      "schedule": "0 0 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "/api/sitemap"
    }
  ]
}
